						{"name": "Disable Scheduler", "priority":0, "action": "sh bin/disable.sh", "if": "\"/etc/upstart/onlinescreensaver.conf\" -f" },
						{"name": "Set Update Interval",
							"items": [
								{"name": "5 Min (Fast/Test)", "action": "sh bin/set_interval.sh 5"},
								{"name": "15 Minutes",        "action": "sh bin/set_interval.sh 15"},
								{"name": "30 Minutes",        "action": "sh bin/set_interval.sh 30"},
								{"name": "1 Hour (Normal)",   "action": "sh bin/set_interval.sh 60"},
								{"name": "3 Hours",           "action": "sh bin/set_interval.sh 180"},
								{"name": "6 Hours",           "action": "sh bin/set_interval.sh 360"},
								{"name": "12 Hours",          "action": "sh bin/set_interval.sh 720"},
								{"name": "24 Hours (Daily)",  "action": "sh bin/set_interval.sh 1440"}
							]
						}
					]
				},
				{"name": "Maintenance",
					"items": [
						{"name": "Check Status",                   "priority":0, "action": "sh bin/status.sh"},
